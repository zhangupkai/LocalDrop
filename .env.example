# LocalDrop Configuration
# Copy this file to .env and modify as needed

# Server port (default: 9999)
PORT=9999

# Upload files directory (default: ./uploads)
UPLOADS_DIR=./uploads

# Admin secret key (required for admin features)
# ADMIN_KEY=your-secret-key-here

# Admin session TTL in hours (default: 4)
ADMIN_SESSION_TTL=4

# Max single file size in bytes (default: 5GB)
MAX_FILE_SIZE=5368709120

# Max total storage in bytes (default: 50GB)
MAX_TOTAL_STORAGE=53687091200

# Auto-expire content after N days (default: 7)
EXPIRE_DAYS=7
